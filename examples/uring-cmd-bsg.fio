# io_uring_cmd I/O engine for block SCSI generic character device

[global]
filename=/dev/bsg/0\:0\:0\:0
ioengine=io_uring_cmd
cmd_type=bsg
size=1G
iodepth=32
bs=4KB
stonewall=1

[rand-write]
rw=randwrite

[rand-read]
rw=randread

[trimwrite]
rw=trimwrite

[writefua]
rw=write
writefua=1

[readfua]
rw=read
readfua=1

[fsync]
rw=write
fsync=1
